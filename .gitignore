# Environment / secrets
.env
.env.*
!.env.example

# Node
node_modules/
**/node_modules/

# Logs / runtime
logs/
*.log

# Backups / exports
backups/
exports/

# SQLite runtime DB
data/*.sqlite
data/*.sqlite-*
data/*.db
data/*.db-*

# Temporary patch backups
*.before-*
*.broken-backup
*.bak
*.tmp

# OS
.DS_Store
Thumbs.db

# Generated bulky media
generated-videos/
*.mp4
*.mov
*.webm

# Keep folder placeholders
!logs/.gitkeep
!logs/jobs/.gitkeep
!logs/worker/.gitkeep
!logs/nightly/.gitkeep
!data/.gitkeep
!exports/.gitkeep
!backups/.gitkeep

# Generated app/runtime state
apps/auto-*.html
tools/video-generator/processed*.json
tools/publish/review-db.json
tools/autopilot/autopilot-state.json
tools/autopilot/content-ledger.json

# Analytics/runtime state
tools/analytics/advanced-warehouse.json
tools/analytics/performance-db.json
tools/analytics/recommendations-v2.json
tools/jobs/job-status.json

# Local audio/generated assets
assets/music/*.wav
assets/sfx/*.wav
assets/intro_audio.mp4
assets/outro_audio.mp4
